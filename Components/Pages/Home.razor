@page "/"
@rendermode InteractiveServer
@inject EnterBridge.Services.EnterBridgeApiClient Api
@inject EnterBridge.Services.CartService Cart
@inject NavigationManager Nav

<PageTitle>Products - EnterBridge</PageTitle>

<div class="d-flex flex-wrap align-items-center justify-content-between mb-3 gap-2">
    <h2 class="mb-0">Product Catalog</h2>
    <div class="d-flex gap-2 flex-wrap">
        <input type="text" class="form-control" style="max-width: 220px"
               placeholder="Search products..." @bind="searchTerm" @bind:event="oninput"
               @onkeydown="HandleSearchKey" />
        <select class="form-select" style="max-width: 180px" @onchange="OnCategoryChanged">
            <option value="">All Categories</option>
            @foreach (var cat in categories)
            {
                <option value="@cat" selected="@(cat == selectedCategory)">@cat</option>
            }
        </select>
        <button class="btn btn-primary" @onclick="Search">Search</button>
    </div>
</div>

@if (loading)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"></div></div>
}
else if (products == null || !products.Items.Any())
{
    <div class="alert alert-info">No products found.</div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-3">
        @foreach (var p in products.Items)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="card-title mb-0">@p.Name</h6>
                            <span class="badge bg-secondary ms-2 text-nowrap">@p.Category</span>
                        </div>
                        <p class="text-muted small mb-2 flex-grow-1">@p.Description</p>
                        <div class="text-muted small mb-2">SKU: @p.Sku</div>
                        <div class="d-flex gap-2 mt-auto">
                            <a href="/products/@p.Id" class="btn btn-sm btn-outline-primary flex-fill">
                                <i class="bi bi-graph-up"></i> Details
                            </a>
                            <button class="btn btn-sm btn-success flex-fill" @onclick="() => AddToCart(p)">
                                <i class="bi bi-cart-plus"></i> Add
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    <div class="mt-4 d-flex flex-wrap justify-content-center align-items-center gap-3">
        <ul class="pagination mb-0">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="() => LoadPage(1)">First</button>
            </li>
            <li class="page-item @(products.HasPreviousPage ? "" : "disabled")">
                <button class="page-link" @onclick="() => LoadPage(currentPage - 1)">Previous</button>
            </li>
            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(products.TotalPages, currentPage + 2); i++)
            {
                var pg = i;
                <li class="page-item @(pg == currentPage ? "active" : "")">
                    <button class="page-link" @onclick="() => LoadPage(pg)">@pg</button>
                </li>
            }
            <li class="page-item @(products.HasNextPage ? "" : "disabled")">
                <button class="page-link" @onclick="() => LoadPage(currentPage + 1)">Next</button>
            </li>
            <li class="page-item @(currentPage == products.TotalPages ? "disabled" : "")">
                <button class="page-link" @onclick="() => LoadPage(products.TotalPages)">Last</button>
            </li>
        </ul>
        <div class="d-flex align-items-center gap-2">
            <label class="form-label mb-0 text-muted small text-nowrap">Per page:</label>
            <select class="form-select form-select-sm" style="width: auto" @onchange="OnPageSizeChanged">
                @foreach (var size in pageSizeOptions)
                {
                    <option value="@size" selected="@(size == pageSize)">@size</option>
                }
            </select>
        </div>
    </div>
    <p class="text-center text-muted small mt-2">Showing page @currentPage of @products.TotalPages (@products.TotalCount products)</p>
}

@if (!string.IsNullOrEmpty(addedMessage))
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050">
        <div class="toast show align-items-center text-bg-success border-0">
            <div class="d-flex">
                <div class="toast-body">@addedMessage</div>
            </div>
        </div>
    </div>
}

@code {
    private PagedResult<Product>? products;
    private List<string> categories = [];
    private string? selectedCategory;
    private string? searchTerm;
    private int currentPage = 1;
    private int pageSize = 20;
    private int[] pageSizeOptions = [10, 20, 50, 100];
    private bool loading = true;
    private string? addedMessage;

    protected override async Task OnInitializedAsync()
    {
        var stats = await Api.GetStatsAsync();
        if (stats != null)
            categories = stats.ProductsByCategory.Keys.OrderBy(k => k).ToList();
        await LoadPage(1);
    }

    private async Task LoadPage(int page)
    {
        loading = true;
        currentPage = page;
        products = await Api.GetProductsAsync(page, pageSize, selectedCategory, searchTerm);
        loading = false;
    }

    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
        {
            pageSize = size;
            await LoadPage(1);
        }
    }

    private async Task OnCategoryChanged(ChangeEventArgs e)
    {
        selectedCategory = e.Value?.ToString();
        if (string.IsNullOrEmpty(selectedCategory)) selectedCategory = null;
        await LoadPage(1);
    }

    private async Task Search()
    {
        await LoadPage(1);
    }

    private async Task HandleSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await LoadPage(1);
    }

    private async Task AddToCart(Product product)
    {
        var price = await Api.GetLatestPriceAsync(product.Id);
        if (price != null)
        {
            Cart.AddItem(product, price);
            addedMessage = $"Added {product.Name} to cart";
            StateHasChanged();
            _ = ClearMessage();
        }
    }

    private async Task ClearMessage()
    {
        await Task.Delay(2000);
        addedMessage = null;
        await InvokeAsync(StateHasChanged);
    }
}
